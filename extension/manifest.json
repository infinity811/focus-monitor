{
  "manifest_version": 3,
  "name": "Focus Monitor",
  "version": "1.0.0",
  "description": "Track your focus, posture, and alertness using webcam face detection. Pomodoro timer, ambient sounds, streaks, and more. All processing runs locally.",
  "permissions": [
    "notifications",
    "storage"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open Focus Monitor"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
